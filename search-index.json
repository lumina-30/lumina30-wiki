:root{--ink:#18211b;--paper:#f5f2e9;--panel:#fffdf7;--line:#d8d4c8;--green:#245946;--mint:#cfe5d7;--amber:#f2c66d;--blue:#cbdde8;--rose:#e8c8bd;--muted:#647069;--shadow:0 18px 50px #18211b14}*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;background:var(--paper);color:var(--ink);font:16px/1.65 Inter,system-ui,-apple-system,"Segoe UI",sans-serif}a{color:inherit}.top{position:sticky;top:0;z-index:10;background:#f5f2e9eb;backdrop-filter:blur(16px);border-bottom:1px solid var(--line)}.top nav{max-width:1180px;margin:auto;min-height:72px;padding:0 24px;display:flex;align-items:center;justify-content:space-between}.brand{text-decoration:none;font-weight:850;letter-spacing:-.03em}.brand small{font-weight:500;color:var(--muted);margin-left:.45rem}.navlinks{display:flex;align-items:center;gap:24px}.navlinks a,.search-open{font:inherit;font-size:.9rem;text-decoration:none;background:none;border:0;cursor:pointer}.search-open,.menu{padding:8px 10px;border:1px solid var(--line);border-radius:8px;background:none}.menu{display:none}.notice{background:var(--ink);color:#fff;padding:10px 24px;text-align:center;font-size:.88rem}.notice strong{color:var(--amber)}.hero,.section,.article,footer{max-width:1180px;margin:auto}.hero.home{padding:105px 24px 94px}.eyebrow{text-transform:uppercase;letter-spacing:.13em;font-size:.72rem;font-weight:850;color:var(--green)}h1,h2,strong{letter-spacing:-.025em}h1{font:500 clamp(3rem,8vw,7rem)/.92 Georgia,serif;margin:18px 0 28px}h1 i{color:var(--green)}.lead{max-width:760px;font-size:clamp(1.05rem,2.1vw,1.4rem);color:#46524b}.actions{display:flex;gap:12px;margin-top:36px}.actions a,.bridge>a{padding:13px 18px;border:1px solid;border-radius:999px;text-decoration:none;font-weight:750}.actions .primary{background:var(--ink);color:white}.section{padding:80px 24px}.section>h2,.related>h2{font:500 clamp(2.2rem,5vw,4.3rem)/1 Georgia,serif;margin:10px 0 24px}.question-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}.question{min-height:260px;padding:26px;border-radius:18px;text-decoration:none;display:flex;flex-direction:column;border:1px solid #18211b1f;transition:.2s}.question:hover,.card:hover{transform:translateY(-3px);box-shadow:var(--shadow)}.question span{font-size:.75rem;font-weight:800}.question strong{font-size:clamp(1.4rem,3vw,2.4rem);line-height:1.08;margin:auto 0}.question em{font-style:normal;font-weight:750;font-size:.9rem}.q1{background:var(--mint)}.q2{background:var(--amber)}.q3{background:var(--blue)}.q4{background:var(--rose)}.bridge{max-width:1132px;margin:20px auto;padding:52px;background:var(--green);color:#fff;border-radius:24px;display:grid;grid-template-columns:1fr auto;gap:40px;align-items:end}.bridge .eyebrow{color:var(--amber)}.bridge h2{font:500 clamp(2rem,4vw,3.8rem)/1.06 Georgia,serif;margin:12px 0}.bridge>a{white-space:nowrap}.intro,.card p,.back,footer,.article-grid aside p{color:var(--muted)}.cards{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:32px}.card{background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:22px;text-decoration:none;min-height:190px;transition:.2s}.card span{font-size:.68rem;text-transform:uppercase;letter-spacing:.1em;color:var(--green);font-weight:800}.card strong{display:block;font-size:1.3rem;margin:20px 0 8px}.card p{font-size:.9rem;margin:0}.article{padding:30px 24px 90px}.back{display:inline-block;margin:18px 0 34px;text-decoration:none}.hero.compact{padding:45px 0 55px;border-bottom:1px solid var(--line)}.hero.compact h1{font-size:clamp(3rem,7vw,6rem)}.article-grid{display:grid;grid-template-columns:270px 1fr;gap:70px;padding-top:56px}.article-grid aside{position:sticky;top:100px;align-self:start;background:var(--panel);border:1px solid var(--line);padding:20px;border-radius:14px;font-size:.9rem}.article-grid aside nav{border-top:1px solid var(--line);padding-top:12px}.article-grid aside a{display:block;padding:6px 0;text-decoration:none}.prose{max-width:740px}.prose section{padding-bottom:38px;margin-bottom:38px;border-bottom:1px solid var(--line)}.prose h2{font:500 2rem/1.1 Georgia,serif}.prose p,.prose li{font-size:1.05rem}.sources{list-style:none;padding:0}.sources a{display:flex;justify-content:space-between;padding:12px 0;border-bottom:1px solid var(--line);font-weight:700;text-decoration:none}.source-note{padding:14px;background:var(--mint);border-radius:8px;font-size:.9rem!important}.related{padding-top:80px}.wide{max-width:820px;margin:auto;padding-top:50px}.source-index{padding:0;list-style:none}.source-index li{padding:16px 0;border-bottom:1px solid var(--line)}.source-index a{font-weight:750}.source-index small{display:block;color:var(--muted);overflow-wrap:anywhere}footer{border-top:1px solid var(--line);padding:36px 24px;display:flex;justify-content:space-between;font-size:.85rem}footer p{margin:5px 0}footer div:last-child{display:flex;gap:18px}dialog{width:min(680px,calc(100% - 28px));border:1px solid var(--line);border-radius:16px;padding:24px;background:var(--panel);color:var(--ink);box-shadow:var(--shadow)}dialog::backdrop{background:#18211ba6}dialog form{text-align:right}dialog form button{border:0;background:none;font-size:1.8rem}dialog label{display:block;font-weight:800;margin-bottom:8px}dialog input{width:100%;font:inherit;font-size:1.1rem;padding:14px;border:1px solid var(--line);border-radius:10px}#results a{display:block;padding:14px 0;border-bottom:1px solid var(--line);text-decoration:none}#results small{display:block;color:var(--muted)}@media(max-width:800px){.brand small,.navlinks{display:none}.menu{display:block}.navlinks.open{position:absolute;display:flex;top:72px;left:0;right:0;background:var(--paper);padding:20px 24px;border-bottom:1px solid var(--line);flex-wrap:wrap}.hero.home{padding-top:70px}.question-grid,.cards,.article-grid,.bridge{grid-template-columns:1fr}.question{min-height:210px}.bridge{margin:12px;padding:30px}.article-grid{gap:30px}.article-grid aside{position:static}.cards{grid-template-columns:1fr 1fr}footer{display:block}footer div:last-child{margin-top:20px;flex-wrap:wrap}}@media(max-width:520px){.cards{grid-template-columns:1fr}.actions{display:block}.actions a{display:block;text-align:center;margin:9px 0}h1{font-size:3.15rem}.article{padding-left:18px;padding-right:18px}}
